{
  "name": "SmtpAccount",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for this SMTP"
    },
    "host": {
      "type": "string"
    },
    "port": {
      "type": "number",
      "default": 587
    },
    "secure": {
      "type": "boolean",
      "default": true
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "from_email": {
      "type": "string"
    },
    "from_name": {
      "type": "string"
    },
    "imap_host": {
      "type": "string"
    },
    "imap_port": {
      "type": "number"
    },
    "daily_limit": {
      "type": "number",
      "default": 500
    },
    "sent_today": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "error"
      ],
      "default": "active"
    },
    "is_verified": {
      "type": "boolean",
      "default": false
    },
    "warmup_enabled": {
      "type": "boolean",
      "default": false
    },
    "warmup_days": {
      "type": "number",
      "default": 0,
      "description": "Number of warmup days completed"
    }
  },
  "required": [
    "name",
    "host",
    "username",
    "password",
    "from_email"
  ]
}